# API Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Database Settings
DATABASE_URL=sqlite:///./devtool.db

# LLM Providers Configuration
# Supported providers: gemini, openai, ollama, mock
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash

# Gemini Configuration (Required for cloud embeddings and LLM)
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI Configuration (Optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Ollama Configuration (Optional - for local LLM models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embeddings Configuration
# Options: gemini (Google Generative AI - default, works in cloud)
#          local (SentenceTransformers - requires: pip install sentence-transformers langchain-huggingface)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
